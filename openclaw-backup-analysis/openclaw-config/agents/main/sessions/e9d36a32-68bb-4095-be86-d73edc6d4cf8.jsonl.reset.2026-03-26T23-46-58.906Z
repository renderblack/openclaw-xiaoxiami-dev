w/workspace/docs-library/memory-system.md\n/home/openclaw/.openclaw/workspace/docs-library/overview.md\n/home/openclaw/.openclaw/workspace/docs-library/README.md\n/home/openclaw/.openclaw/workspace/docs-library/skills.md\n/home/openclaw/.openclaw/workspace/docs-library/troubleshooting.md\n/home/openclaw/.openclaw/workspace/HEARTBEAT.md\n/home/openclaw/.openclaw/workspace/IDENTITY.md\n/home/openclaw/.openclaw/workspace/memory/2026-03-26.md\n/home/openclaw/.openclaw/workspace/MEMORY.md\n/home/openclaw/.openclaw/workspace/memory/projects/openclaw.md\n/home/openclaw/.openclaw/workspace/memory/README.md\n/home/openclaw/.openclaw/workspace/SOUL.md\n/home/openclaw/.openclaw/workspace/TOOLS.md\n/home/openclaw/.openclaw/workspace/USER.md","cwd":"/home/openclaw/.openclaw/workspace"},"isError":false,"timestamp":1774507021949}}
