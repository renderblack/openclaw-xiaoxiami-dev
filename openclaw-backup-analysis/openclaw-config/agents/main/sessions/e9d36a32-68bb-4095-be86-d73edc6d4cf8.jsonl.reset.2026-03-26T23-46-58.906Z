{"type":"message","id":"0a79e4a0","parentId":"a950d178","timestamp":"2026-03-26T06:21:38.933Z","message":{"role":"toolResult","toolCallId":"call_00_QeTGVE44UQjUkjojVmITQM6s","toolName":"read","content":[{"type":"text","text":"{\n  \"log_rotation_config\": {\n    \"version\": \"1.0\",\n    \"created_at\": \"2026-03-26T00:40:00Z\",\n    \"author\": \"小龙虾🦞\",\n    \"description\": \"OpenClaw日志轮转配置\",\n    \n    \"directories\": {\n      \"log_dir\": \"/home/openclaw/.openclaw/logs\",\n      \"backup_dir\": \"/home/openclaw/.openclaw/log-rotation/backups\",\n      \"state_dir\": \"/home/openclaw/.openclaw/log-rotation/state\"\n    },\n    \n    \"rotation_policy\": {\n      \"frequency\": \"daily\",\n      \"time\": \"02:00\",\n      \"timezone\": \"UTC+8\",\n      \"trigger\": \"time_based\"\n    },\n    \n    \"retention_policy\": {\n      \"keep_days\": 30,\n      \"compress_after_days\": 7,\n      \"max_total_size\": \"1GB\",\n      \"cleanup_schedule\": \"daily\"\n    },\n    \n    \"compression_settings\": {\n      \"method\": \"gzip\",\n      \"level\": 9,\n      \"remove_original\": true,\n      \"suffix\": \".gz\"\n    },\n    \n    \"file_patterns\": {\n      \"include\": [\"*.log\", \"*.jsonl\", \"*.txt\"],\n      \"exclude\": [\"*.gz\", \"*.bz2\", \"*.zip\"],\n      \"min_size_to_rotate\": \"1KB\",\n      \"min_size_to_compress\": \"10KB\"\n    },\n    \n    \"monitoring\": {\n      \"generate_report\": true,\n      \"report_location\": \"/home/openclaw/.openclaw/log-rotation/state\",\n      \"notify_on_error\": true,\n      \"log_rotation_events\": true\n    },\n    \n    \"scripts\": {\n      \"rotation_script\": \"/home/openclaw/.openclaw/log-rotation/logrotate.sh\",\n      \"test_script\": \"/home/openclaw/.openclaw/log-rotation/test.sh\",\n      \"restore_script\": \"/home/openclaw/.openclaw/log-rotation/restore.sh\"\n    },\n    \n    \"safety_features\": {\n      \"dry_run_option\": true,\n      \"backup_before_rotation\": false,\n      \"max_file_age_before_deletion\": \"90 days\",\n      \"emergency_stop_file\": \"/home/openclaw/.openclaw/log-rotation/STOP\"\n    }\n  }\n}"}],"isError":false,"timestamp":1774506098917}}
