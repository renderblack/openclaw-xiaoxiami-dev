{"type":"message","id":"422d4c64","parentId":"2767692a","timestamp":"2026-03-26T02:27:12.703Z","message":{"role":"toolResult","toolCallId":"call_645e2adda4504b6a86ab1bf5","toolName":"read","content":[{"type":"text","text":"    find \"$backup_dir\" -name \"backup_${BACKUP_TYPE}_*.tar.gz\" -type f -mtime +$keep_days -delete\n    \n    local remaining=$(find \"$backup_dir\" -name \"backup_${BACKUP_TYPE}_*.tar.gz\" -type f | wc -l)\n    log_info \"清理完成，剩余备份文件: $remaining\"\n}\n\n# 主函数\nmain() {\n    log_info \"=== OpenClaw 备份脚本 ===\"\n    log_info \"备份类型: $BACKUP_TYPE\"\n    log_info \"时间戳: $TIMESTAMP\"\n    \n    check_directories\n    \n    # 创建备份\n    backup_file=$(create_backup)\n    \n    # 清理旧备份\n    cleanup_old_backups\n    \n    # 生成报告\n    cat > \"$BACKUP_ROOT/last_backup.log\" << EOF\n=== 备份完成报告 ===\n时间: $(date)\n类型: $BACKUP_TYPE\n文件: $(basename \"$backup_file\")\n大小: $(du -h \"$backup_file\" | cut -f1)\n状态: 成功\nEOF\n    \n    log_info \"备份流程完成\"\n}\n\n# 执行主函数\nmain \"$@\""}],"isError":false,"timestamp":1774492032678}}
